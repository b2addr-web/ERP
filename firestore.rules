rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && request.auth.token.email == 'b2addr@gmail.com';
    }

    function isAnon() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let u = getUserData();
      return isSignedIn() && (
        isOwner() ||
        isAnon() ||
        (u != null && u.get('role', 'STAFF') == 'ADMIN' && u.get('isApproved', false) == true)
      );
    }

    function isApprovedUser() {
      let u = getUserData();
      return isSignedIn() && (
        isAdmin() ||
        (u != null && u.get('isApproved', false) == true)
      );
    }

    // ── /users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // ✅ FIX: المستخدم يقدر يقرأ/يكتب بياناته الخاصة دائماً
      allow read:   if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // ✅ FIX: السماح بإنشاء الـ profile عند أول تسجيل دخول
      allow create: if isSignedIn() && request.auth.uid == userId;
      // تحديث: المستخدم يعدل بياناته أو الأدمن يعدل أي بيانات
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── /finance ──────────────────────────────────────────────────────────────
    match /finance/{docId} {
      allow read:   if isApprovedUser();
      allow write:  if isAdmin();
    }
    match /finance/{docId}/{sub=**} {
      allow read:   if isApprovedUser();
      allow write:  if isAdmin();
    }

    // ── /procurement ──────────────────────────────────────────────────────────
    match /procurement/{docId} {
      allow read:   if isApprovedUser();
      allow write:  if isAdmin();
    }
    match /procurement/{docId}/{sub=**} {
      allow read:   if isApprovedUser();
      allow write:  if isAdmin();
    }

    // ── /sales ────────────────────────────────────────────────────────────────
    match /sales/{docId} {
      allow read:   if isApprovedUser();
      allow write:  if isAdmin();
    }
    match /sales/{docId}/{sub=**} {
      allow read:   if isApprovedUser();
      allow write:  if isAdmin();
    }

    // ── /settings ─────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read:   if isApprovedUser();
      allow write:  if isAdmin();
    }

    // ── test connection ───────────────────────────────────────────────────────
    match /test/{docId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ── Default: deny all ─────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
